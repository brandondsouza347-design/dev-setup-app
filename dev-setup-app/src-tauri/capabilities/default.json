{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Dev Setup App",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-execute",
    "shell:allow-open",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-write-text-file",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:allow-exists",
    "fs:scope-appdata-recursive",
    "fs:scope-home-recursive",
    "fs:scope-resource-recursive",
    "fs:default",
    "os:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "notification:default"
  ]
}
