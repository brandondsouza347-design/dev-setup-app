{
	"$schema": "../node_modules/@tauri-apps/cli/schema.json",
	"productName": "Dev_Setup",
	"version": "1.8.6",
	"identifier": "com.devsetup.app",
	"build": {
		"beforeDevCommand": "npm run dev",
		"beforeBuildCommand": "npm run build",
		"devUrl": "http://localhost:1420",
		"frontendDist": "../dist"
	},
	"app": {
		"withGlobalTauri": true,
		"windows": [
			{
				"fullscreen": false,
				"resizable": true,
				"title": "Dev Environment Setup",
				"width": 1000,
				"height": 720,
				"minWidth": 900,
				"minHeight": 650
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/256x256.png",
			"icons/512x512.png",
			"icons/icon.ico",
			"icons/icon.icns"
		],
		"resources": {
			"../scripts": "scripts"
		},
		"copyright": "",
		"category": "DeveloperTool",
		"shortDescription": "Developer Environment Setup Tool",
		"longDescription": "Cross-platform automated developer environment installer for macOS and Windows.",
		"macOS": {
			"entitlements": null,
			"exceptionDomain": "",
			"frameworks": [],
			"providerShortName": null,
			"signingIdentity": null
		},
		"windows": {
			"certificateThumbprint": null,
			"digestAlgorithm": "sha256",
			"timestampUrl": ""
		}
	}
}
